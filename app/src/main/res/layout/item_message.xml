<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="@dimen/spacing_xs">

    <!-- User Message (right aligned) -->
    <LinearLayout
        android:id="@+id/userBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:orientation="vertical"
        android:background="@drawable/bg_bubble_user"
        android:padding="@dimen/spacing_lg"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvUserContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="@dimen/text_base"
            android:textColor="@color/md_on_surface"
            android:lineSpacingMultiplier="1.4"
            tools:text="Help me build a React counter component" />

        <TextView
            android:id="@+id/tvUserTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textSize="@dimen/text_xs"
            android:textColor="@color/md_on_surface_variant"
            android:layout_marginTop="@dimen/spacing_xs"
            tools:text="14:30" />

    </LinearLayout>

    <!-- AI Message (left aligned) -->
    <LinearLayout
        android:id="@+id/aiBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="64dp"
        android:orientation="horizontal"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- AI Avatar -->
        <FrameLayout
            android:layout_width="@dimen/avatar_sm"
            android:layout_height="@dimen/avatar_sm"
            android:layout_marginTop="4dp">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_primary_circle" />

        </FrameLayout>

        <!-- Bubble content -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_sm"
            android:background="@drawable/bg_bubble_ai"
            android:padding="@dimen/spacing_lg">

            <!-- Markdown content rendered here -->
            <TextView
                android:id="@+id/tvAiContent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_base"
                android:textColor="@color/md_on_surface"
                android:lineSpacingMultiplier="1.4"
                tools:text="Sure, I'll create a React counter for you!" />

            <!-- Tool call chip -->
            <com.google.android.material.chip.Chip
                android:id="@+id/chipToolCall"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:visibility="gone"
                style="@style/Widget.Material3.Chip.Assist"
                android:textSize="@dimen/text_xs"
                app:chipBackgroundColor="@color/md_surface_container_high"
                app:chipCornerRadius="@dimen/radius_full"
                tools:text="calculator"
                tools:visibility="visible" />

            <!-- Token/time info -->
            <TextView
                android:id="@+id/tvAiMeta"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textSize="@dimen/text_xs"
                android:textColor="@color/md_on_surface_variant"
                android:layout_marginTop="@dimen/spacing_xs"
                android:fontFamily="monospace"
                tools:text="1.2s · 342 tokens" />

        </LinearLayout>

    </LinearLayout>

</FrameLayout>
