<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/md_surface">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="@dimen/toolbar_height"
            android:background="@color/surface_80"
            android:elevation="0dp"
            app:navigationIcon="@android:drawable/ic_menu_revert"
            app:navigationIconTint="@color/md_on_surface" />

        <androidx.core.widget.NestedScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="@dimen/spacing_lg"
                android:paddingBottom="100dp">

                <!-- Title -->
                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Persona"
                    android:textSize="@dimen/text_3xl"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface"
                    android:letterSpacing="-0.02" />

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="여러 AI 페르소나를 만들고 전환할 수 있습니다"
                    android:textSize="@dimen/text_base"
                    android:textColor="@color/md_on_surface_variant"
                    android:layout_marginTop="@dimen/spacing_xs"
                    android:layout_marginBottom="@dimen/spacing_2xl" />

                <!-- Persona list container -->
                <LinearLayout
                    android:id="@+id/personaListContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Empty state -->
                <TextView
                    android:id="@+id/tvEmpty"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="아직 페르소나가 없습니다.\n아래 + 버튼으로 추가해 보세요."
                    android:textSize="@dimen/text_base"
                    android:textColor="@color/md_on_surface_variant"
                    android:gravity="center"
                    android:paddingVertical="40dp"
                    android:visibility="gone" />

            </LinearLayout>

        </androidx.core.widget.NestedScrollView>

    </LinearLayout>

    <!-- FAB: Add persona -->
    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddPersona"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="@dimen/spacing_xl"
        android:text="페르소나 추가"
        app:icon="@android:drawable/ic_input_add"
        app:layout_anchorGravity="bottom|end" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>

