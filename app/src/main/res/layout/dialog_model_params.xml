<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="@dimen/spacing_lg">

    <TextView
        android:id="@+id/tvDialogModelName"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text=""
        android:textSize="@dimen/text_base"
        android:textColor="@color/md_primary"
        android:textStyle="bold"
        android:layout_marginBottom="@dimen/spacing_md" />

    <TextView
        android:id="@+id/tvDialogTemperature"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Temperature: 0.70"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/md_on_surface_variant" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderDialogTemperature"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0.0"
        android:valueTo="2.0"
        android:stepSize="0.05" />

    <TextView
        android:id="@+id/tvDialogTopP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Top P: 0.95"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginTop="@dimen/spacing_sm" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderDialogTopP"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="0.0"
        android:valueTo="1.0"
        android:stepSize="0.05" />

    <TextView
        android:id="@+id/tvDialogMaxTokens"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Max Tokens: 4096"
        android:textSize="@dimen/text_sm"
        android:textColor="@color/md_on_surface_variant"
        android:layout_marginTop="@dimen/spacing_sm" />

    <com.google.android.material.slider.Slider
        android:id="@+id/sliderDialogMaxTokens"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:valueFrom="256"
        android:valueTo="8192"
        android:stepSize="256" />

</LinearLayout>
