<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/conversationListFragment">

    <!-- Chat Flow -->
    <fragment
        android:id="@+id/conversationListFragment"
        android:name="com.clawdroid.feature.chat.ui.ConversationListFragment"
        android:label="@string/nav_chat"
        tools:layout="@layout/fragment_conversation_list">
        <action
            android:id="@+id/action_conversationList_to_chat"
            app:destination="@id/chatFragment" />
    </fragment>

    <fragment
        android:id="@+id/chatFragment"
        android:name="com.clawdroid.feature.chat.ui.ChatFragment"
        android:label="Chat"
        tools:layout="@layout/fragment_chat">
        <argument
            android:name="conversationId"
            app:argType="string"
            app:nullable="true"
            android:defaultValue="@null" />
    </fragment>

    <!-- Voice Flow -->
    <fragment
        android:id="@+id/voiceChatFragment"
        android:name="com.clawdroid.feature.voice.ui.VoiceChatFragment"
        android:label="@string/nav_voice"
        tools:layout="@layout/fragment_voice_chat" />

    <!-- Channel Flow -->
    <fragment
        android:id="@+id/channelListFragment"
        android:name="com.clawdroid.feature.channels.ui.ChannelListFragment"
        android:label="@string/nav_channels"
        tools:layout="@layout/fragment_channel_list">
        <action
            android:id="@+id/action_channelList_to_channelAdd"
            app:destination="@id/channelAddFragment" />
        <action
            android:id="@+id/action_channelList_to_channelDetail"
            app:destination="@id/channelDetailFragment" />
    </fragment>

    <fragment
        android:id="@+id/channelAddFragment"
        android:name="com.clawdroid.feature.channels.ui.ChannelAddFragment"
        android:label="채널 추가" />

    <fragment
        android:id="@+id/channelDetailFragment"
        android:name="com.clawdroid.feature.channels.ui.ChannelDetailFragment"
        android:label="채널 상세">
        <argument
            android:name="channelId"
            app:argType="long" />
    </fragment>

    <!-- Settings Flow -->
    <fragment
        android:id="@+id/settingsFragment"
        android:name="com.clawdroid.feature.settings.ui.SettingsFragment"
        android:label="@string/nav_settings"
        tools:layout="@layout/fragment_settings">
        <action
            android:id="@+id/action_settings_to_modelSettings"
            app:destination="@id/modelSettingsFragment" />
        <action
            android:id="@+id/action_settings_to_personaSettings"
            app:destination="@id/personaSettingsFragment" />
        <action
            android:id="@+id/action_settings_to_securitySettings"
            app:destination="@id/securitySettingsFragment" />
        <action
            android:id="@+id/action_settings_to_toolSettings"
            app:destination="@id/toolSettingsFragment" />
        <action
            android:id="@+id/action_settings_to_about"
            app:destination="@id/aboutFragment" />
    </fragment>

    <fragment
        android:id="@+id/modelSettingsFragment"
        android:name="com.clawdroid.feature.settings.ui.ModelSettingsFragment"
        android:label="AI Models"
        tools:layout="@layout/fragment_model_settings" />

    <fragment
        android:id="@+id/personaSettingsFragment"
        android:name="com.clawdroid.feature.settings.ui.PersonaSettingsFragment"
        android:label="Persona"
        tools:layout="@layout/fragment_persona_settings" />

    <fragment
        android:id="@+id/securitySettingsFragment"
        android:name="com.clawdroid.feature.settings.ui.SecuritySettingsFragment"
        android:label="Security"
        tools:layout="@layout/fragment_security_settings" />

    <fragment
        android:id="@+id/toolSettingsFragment"
        android:name="com.clawdroid.feature.tools.ui.ToolSettingsFragment"
        android:label="도구 · 스킬">
        <action
            android:id="@+id/action_toolSettings_to_skillSettings"
            app:destination="@id/skillSettingsFragment" />
    </fragment>

    <fragment
        android:id="@+id/skillSettingsFragment"
        android:name="com.clawdroid.feature.tools.ui.SkillSettingsFragment"
        android:label="스킬 관리" />

    <fragment
        android:id="@+id/aboutFragment"
        android:name="com.clawdroid.feature.settings.ui.AboutFragment"
        android:label="앱 정보"
        tools:layout="@layout/fragment_about" />

</navigation>
