<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Toolbar -->
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="채널 추가"
            app:navigationIcon="@android:drawable/ic_menu_close_clear_cancel" />

        <!-- Channel Type Selection -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="채널 타입"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <RadioGroup
            android:id="@+id/rgChannelType"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">

            <RadioButton
                android:id="@+id/rbTelegram"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="✈️ Telegram"
                android:checked="true" />

            <RadioButton
                android:id="@+id/rbDiscord"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🎮 Discord" />

            <RadioButton
                android:id="@+id/rbSlack"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="💼 Slack" />

            <RadioButton
                android:id="@+id/rbGateway"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="🌐 Gateway" />
        </RadioGroup>

        <!-- Channel Name -->
        <com.google.android.material.textfield.TextInputLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:hint="채널 이름">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etChannelName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Bot Token -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilBotToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Bot Token"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etBotToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- App Token (Slack only) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAppToken"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="App Token (Slack)"
            android:visibility="gone"
            app:endIconMode="password_toggle">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAppToken"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textPassword" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- Server URL (Gateway only) -->
        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilServerUrl"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:hint="Server URL"
            android:visibility="gone">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etServerUrl"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="textUri" />
        </com.google.android.material.textfield.TextInputLayout>

        <!-- DM Policy -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="DM 정책"
            android:textSize="14sp"
            android:textStyle="bold"
            android:layout_marginTop="16dp" />

        <com.google.android.material.chip.ChipGroup
            android:id="@+id/chipGroupPolicy"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:singleSelection="true"
            app:selectionRequired="true">

            <com.google.android.material.chip.Chip
                android:id="@+id/chipPairing"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔒 페어링"
                android:checked="true" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipOpen"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔓 공개" />

            <com.google.android.material.chip.Chip
                android:id="@+id/chipClosed"
                style="@style/Widget.Material3.Chip.Filter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🚫 차단" />
        </com.google.android.material.chip.ChipGroup>

        <!-- Save Button -->
        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSave"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="채널 추가" />

    </LinearLayout>
</ScrollView>
