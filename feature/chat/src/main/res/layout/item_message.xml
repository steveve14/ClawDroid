<?xml version="1.0" encoding="utf-8"?>
<FrameLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="2dp">

    <!-- User Message (right aligned) -->
    <LinearLayout
        android:id="@+id/userBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:layout_marginStart="64dp"
        android:layout_marginEnd="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_user_bubble"
        android:padding="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvUserContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="@android:color/white"
            tools:text="React 카운터 컴포넌트 만들어줘" />

        <TextView
            android:id="@+id/tvUserTime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textSize="10sp"
            android:textColor="@android:color/white"
            android:alpha="0.7"
            android:layout_marginTop="4dp"
            tools:text="14:30" />

    </LinearLayout>

    <!-- AI Message (left aligned) -->
    <LinearLayout
        android:id="@+id/aiBubble"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:layout_marginEnd="64dp"
        android:layout_marginStart="8dp"
        android:orientation="vertical"
        android:background="@drawable/bg_ai_bubble"
        android:padding="12dp"
        android:visibility="gone"
        tools:visibility="visible">

        <!-- Markdown content rendered here -->
        <TextView
            android:id="@+id/tvAiContent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="15sp"
            android:textColor="?attr/colorOnSurface"
            tools:text="네, React 카운터를 만들어 드릴게요!" />

        <!-- Tool call chip -->
        <com.google.android.material.chip.Chip
            android:id="@+id/chipToolCall"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            style="@style/Widget.Material3.Chip.Assist"
            android:textSize="11sp"
            tools:text="🔧 calculator ✅"
            tools:visibility="visible" />

        <!-- Token/time info -->
        <TextView
            android:id="@+id/tvAiMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textSize="10sp"
            android:textColor="?attr/colorOnSurfaceVariant"
            android:layout_marginTop="4dp"
            tools:text="⏱️ 1.2s · 342 tokens" />

    </LinearLayout>

</FrameLayout>
