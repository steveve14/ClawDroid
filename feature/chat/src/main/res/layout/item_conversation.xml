<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/radius_lg"
    app:cardElevation="0dp"
    app:cardBackgroundColor="@color/md_surface_container_lowest"
    app:strokeWidth="1dp"
    app:strokeColor="@color/outline_variant_10">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="@dimen/spacing_lg">

        <!-- Left purple indicator bar for pinned -->
        <View
            android:id="@+id/pinIndicator"
            android:layout_width="4dp"
            android:layout_height="48dp"
            android:background="@color/md_primary"
            android:layout_marginEnd="@dimen/spacing_md"
            android:visibility="gone" />

        <!-- Avatar -->
        <FrameLayout
            android:layout_width="@dimen/avatar_lg"
            android:layout_height="@dimen/avatar_lg">

            <View
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:background="@drawable/bg_gradient_primary_circle" />

            <ImageView
                android:id="@+id/ivAvatar"
                android:layout_width="21dp"
                android:layout_height="@dimen/icon_md"
                android:layout_gravity="center"
                android:contentDescription="avatar"
                android:src="@android:drawable/sym_def_app_icon" />

        </FrameLayout>

        <!-- Content -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:layout_marginStart="@dimen/spacing_md">

            <!-- Title Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:textSize="@dimen/text_base"
                    android:textStyle="bold"
                    android:textColor="@color/md_on_surface"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Coding Assistant" />

                <TextView
                    android:id="@+id/tvTime"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textSize="@dimen/text_xs"
                    android:textColor="@color/md_on_surface_variant"
                    tools:text="5m ago" />

            </LinearLayout>

            <!-- Preview -->
            <TextView
                android:id="@+id/tvPreview"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:textSize="@dimen/text_sm"
                android:textColor="@color/md_on_surface_variant"
                android:maxLines="2"
                android:ellipsize="end"
                tools:text="Let me help you build a React component..." />

            <!-- Model Badge -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/spacing_sm"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipModel"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:textSize="@dimen/text_xs"
                    app:chipBackgroundColor="@color/md_surface_container_high"
                    app:chipCornerRadius="@dimen/radius_full"
                    app:chipMinHeight="24dp"
                    tools:text="gemini-nano" />

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipChannel"
                    android:layout_width="wrap_content"
                    android:layout_height="24dp"
                    android:layout_marginStart="4dp"
                    android:visibility="gone"
                    style="@style/Widget.Material3.Chip.Assist"
                    android:textSize="@dimen/text_xs"
                    app:chipBackgroundColor="@color/md_surface_container_high"
                    app:chipCornerRadius="@dimen/radius_full"
                    app:chipMinHeight="24dp"
                    tools:text="Telegram" />

            </LinearLayout>

        </LinearLayout>

    </LinearLayout>

</com.google.android.material.card.MaterialCardView>
